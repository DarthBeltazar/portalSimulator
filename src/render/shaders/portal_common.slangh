// Shared types/functions for the Vulkan RT sub-step's portal-hop shaders (docs/phase2-
// rendering.md §7 step 8, DECISIONS.md #0006/#0007). This is a second, hand-written copy of
// manifold-core's portal-crossing math (antipattern #8) — it exists only because a GPU shader
// cannot call the CPU's C++ functions. Every differential test in tests/render/ is the mitigation
// this was built under: identical rays/loops through both implementations must agree within
// float tolerance, every time this file changes.
//
// float, not double (DECISIONS.md #0006's scoped exception to antipattern #3) — GPUs and SPIR-V
// ray tracing are float-native. Bounded by kMaxPortalHops-scale hop counts and validated against
// the exact double CPU reference, never fed back into simulation state.

struct GpuPortalDisk {
    float3 center;
    float3 normal; // unit outward normal
    float radius;
};

// A single-direction SE3 isometry: rotation (quaternion, x,y,z,w) + translation. Both
// transformAtoB and transformBtoA are uploaded precomputed from the CPU's manifold::SE3
// (including its own inverse()), so the shader never has to derive a quaternion inverse itself —
// one less piece of manifold-core math duplicated here.
struct GpuTransform {
    float4 rotation;
    float3 translation;
};

struct GpuPortal {
    GpuPortalDisk diskA;
    GpuPortalDisk diskB;
    GpuTransform transformAtoB;
    GpuTransform transformBtoA;
};

// v' = v + 2*w*cross(qv, v) + 2*cross(qv, cross(qv, v)) — same formula Eigen::Quaterniond's
// operator* on a vector uses (src/manifold/se3.cpp's applyToPoint/applyToVector), ported
// term-for-term rather than reached for a library helper, so it stays auditable against it.
float3 quatRotate(float4 q, float3 v)
{
    float3 qv = q.xyz;
    float3 t = 2.0 * cross(qv, v);
    return v + q.w * t + cross(qv, t);
}

// Hamilton product a*b, both (x,y,z,w) — direct port of Eigen::Quaterniond::operator* (used by
// src/manifold/se3.cpp's SE3::operator*). Not normalized here; callers renormalize, mirroring
// SE3::operator*'s own "renormalize unconditionally, on every composition" discipline
// (CLAUDE.md's manifold-core contract).
float4 quatMultiply(float4 a, float4 b)
{
    return float4(
        a.w * b.x + a.x * b.w + a.y * b.z - a.z * b.y,
        a.w * b.y - a.x * b.z + a.y * b.w + a.z * b.x,
        a.w * b.z + a.x * b.y - a.y * b.x + a.z * b.w,
        a.w * b.w - a.x * b.x - a.y * b.y - a.z * b.z);
}

// this * rhs, matching SE3::operator*'s exact composition order and formula: rhs happens first.
// Direct port of src/manifold/se3.cpp's SE3::operator*.
GpuTransform composeTransform(GpuTransform thisXf, GpuTransform rhs)
{
    GpuTransform result;
    result.rotation = normalize(quatMultiply(thisXf.rotation, rhs.rotation));
    result.translation = quatRotate(thisXf.rotation, rhs.translation) + thisXf.translation;
    return result;
}

// Direct port of the anonymous intersectDisk() in src/manifold/traverse.cpp: ray-plane
// intersection against the disk's supporting plane, then a radius check at the hit point.
// The t > epsilon guard uses a position-adaptive threshold: at large coordinates the float32 ULP
// of `t` exceeds a fixed 1e-4, causing false self-hits (noise). Scaling with the origin's
// magnitude mirrors the adaptive offsetOrigin() in full_scene.slang.
bool intersectDisk(float3 origin, float3 direction, GpuPortalDisk disk, float maxDist, out float outDistance)
{
    outDistance = 0.0;
    float denom = dot(disk.normal, direction);
    if (abs(denom) < 1e-6) {
        return false; // ray parallel to the disk's plane
    }
    float t = dot(disk.normal, disk.center - origin) / denom;
    float maxCoord = max(abs(origin.x), max(abs(origin.y), abs(origin.z)));
    float tMin = max(1e-4, maxCoord * 5e-4);
    if (t <= tMin || t > maxDist) {
        return false;
    }
    float3 hitPoint = origin + t * direction;
    if (length(hitPoint - disk.center) > disk.radius) {
        return false; // beyond the disk's rim
    }
    outDistance = t;
    return true;
}

struct HopStep {
    bool crossed;
    float distanceToHit;
    float3 newOrigin;
    float3 newDirection;
    GpuTransform hopTransform;
};

// Direct port of intersectPortal() + stepThroughNearestPortal() (both in
// src/manifold/traverse.cpp): pick the nearer of a portal's two disks first (CPU's tie-break:
// A wins when both hit and distanceA <= distanceB), matching the CPU's exact comparison
// structure rather than an equivalent-but-differently-ordered one, so the two implementations
// are as mechanically close as antipattern #8's mitigation calls for.
HopStep stepThroughNearestPortalGpu(float3 origin, float3 direction, StructuredBuffer<GpuPortal> portals,
                                     uint portalCount, float maxDistance)
{
    float closestDistance = maxDistance;
    int closestPortal = -1;
    bool closestIsDiskA = false;

    for (uint p = 0; p < portalCount; ++p) {
        GpuPortalDisk diskA = portals[p].diskA;
        GpuPortalDisk diskB = portals[p].diskB;

        float distanceA, distanceB;
        bool hitA = intersectDisk(origin, direction, diskA, closestDistance, distanceA);
        bool hitB = intersectDisk(origin, direction, diskB, closestDistance, distanceB);

        float candidateDistance;
        bool candidateIsDiskA;
        bool candidateHit;
        if (hitA && (!hitB || distanceA <= distanceB)) {
            candidateHit = true;
            candidateDistance = distanceA;
            candidateIsDiskA = true;
        } else if (hitB) {
            candidateHit = true;
            candidateDistance = distanceB;
            candidateIsDiskA = false;
        } else {
            candidateHit = false;
            candidateDistance = 0.0;
            candidateIsDiskA = false;
        }

        if (candidateHit && candidateDistance < closestDistance) {
            closestDistance = candidateDistance;
            closestPortal = int(p);
            closestIsDiskA = candidateIsDiskA;
        }
    }

    HopStep result;
    if (closestPortal < 0) {
        result.crossed = false;
        result.distanceToHit = 0.0;
        result.newOrigin = float3(0, 0, 0);
        result.newDirection = float3(0, 0, 0);
    } else {
        GpuTransform xf = closestIsDiskA ? portals[closestPortal].transformAtoB : portals[closestPortal].transformBtoA;
        float3 hitPoint = origin + closestDistance * direction;
        result.crossed = true;
        result.distanceToHit = closestDistance;
        result.newOrigin = quatRotate(xf.rotation, hitPoint) + xf.translation;
        result.newDirection = quatRotate(xf.rotation, direction);
        result.hopTransform = xf;
    }
    return result;
}
